{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/site/index.html"
    },
    {
      "source": "/site/:path*",
      "destination": "/site/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/site/:path*"
    }
  ]
}
